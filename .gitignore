__pycache__/
*.pyc
*.key
# the demo signing key is PUBLIC on purpose (zero security value) so readers can
# exercise the --verify path against the committed samples
!examples/demo_signing.key
.pcai/
# generated outputs (regenerated by cli.py); the committed sample_*.json and
# demo.html are built from these by tools/build_demo.py
/verify.html
/examples/demo_*.json
